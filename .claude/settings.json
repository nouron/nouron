{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Write",
      "Edit"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__github__merge_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-merge-check.sh",
            "statusMessage": "Merge-Checkliste wird geprüft..."
          }
        ]
      }
    ]
  }
}
