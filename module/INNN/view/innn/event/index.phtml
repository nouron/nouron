<div class="row">
    <div class="col-12">
        <?php if (empty($messages) || count($messages) === 0): ?>
        <p class="text-muted fst-italic">Keine Ereignisse vorhanden.</p>
        <?php else: ?>
        <div class="accordion" id="events-accordion">
        <?php foreach ($messages as $event): ?>
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button"
                            data-bs-toggle="collapse" data-bs-target="#collapse-event-<?php echo $event->getId() ?>"
                            aria-expanded="false">
                        <i class="bi bi-clock me-2"></i>
                        <span class="me-2">Tick <?php echo $event->getTick() ?></span>
                        <span class="badge bg-secondary me-2"><?php echo $event->getArea() ?></span>
                        <?php echo $event->getEvent() ?>
                    </button>
                </h2>
                <div id="collapse-event-<?php echo $event->getId() ?>" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-2">Bereich</dt>
                            <dd class="col-sm-10"><?php echo $event->getArea() ?></dd>
                            <dt class="col-sm-2">Ereignis</dt>
                            <dd class="col-sm-10"><?php echo $event->getEvent() ?></dd>
                            <dt class="col-sm-2">Tick</dt>
                            <dd class="col-sm-10"><?php echo $event->getTick() ?></dd>
                        </dl>
                    </div>
                </div>
            </div>
        <?php endforeach; ?>
        </div>
        <?php endif; ?>
    </div>
</div>
